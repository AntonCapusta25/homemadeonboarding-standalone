{
    "name": "homemade-widget",
    "version": "1.0.0",
    "description": "React widget for ChatGPT Apps - Restaurant Carousel",
    "main": "dist/widget.js",
    "scripts": {
        "build": "esbuild src/index.tsx --bundle --format=esm --outfile=dist/widget.js --minify",
        "dev": "esbuild src/index.tsx --bundle --format=esm --outfile=dist/widget.js --watch"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "esbuild": "^0.19.0",
        "typescript": "^5.3.0"
    }
}